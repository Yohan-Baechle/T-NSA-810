<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CIA - {{ site_name | upper }}</title>
    <style>
        body {
            font-family: sans-serif;
            max-width: 800px;
            margin: 50px auto;
            padding: 0 20px;
            background: #1a1a2e;
            color: #e6e6e6;
        }
        h1 { color: #00d4ff; }
        .info { background: #16213e; padding: 20px; border-radius: 8px; margin: 20px 0; }
        .info p { margin: 5px 0; }
        .status { color: #00ff88; }
    </style>
</head>
<body>
    <h1>Cloud Infrastructure Architects</h1>
    <div class="info">
        <p><strong>Site:</strong> {{ site_name }}</p>
        <p><strong>Hostname:</strong> {{ inventory_hostname }}</p>
        <p><strong>IP:</strong> {{ ansible_host }}</p>
        <p><strong>Domain:</strong> {{ site_domain }}</p>
        <p class="status">Internal network only</p>
    </div>
</body>
</html>

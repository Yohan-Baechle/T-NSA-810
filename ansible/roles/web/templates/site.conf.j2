server {
    listen {{ web_listen_port }};
    server_name {{ web_server_name }};

    root {{ web_root }};
    index index.html;

    # Security headers
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Content-Security-Policy "default-src 'self'; style-src 'self' 'unsafe-inline'" always;

    # Hide Nginx version
    server_tokens off;

    location / {
        try_files $uri $uri/ =404;
    }

    access_log /var/log/nginx/{{ web_server_name }}_access.log;
    error_log /var/log/nginx/{{ web_server_name }}_error.log;
}
